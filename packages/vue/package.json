{
  "name": "@ycloud-web/icons-vue",
  "version": "0.1.0-beta.1",
  "author": "YCloud",
  "description": "A YCloud icon library package for Vue applications.",
  "license": "ISC",
  "homepage": "https://github.com/TianJianJun0727/ycloud-icons",
  "bugs": "https://github.com/TianJianJun0727/ycloud-icons/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TianJianJun0727/ycloud-icons.git",
    "directory": "packages/vue"
  },
  "keywords": [
    "YCloud",
    "Vue",
    "Feather",
    "Icons",
    "Icon",
    "SVG",
    "Feather Icons"
  ],
  "amdName": "ycloud-vue",
  "source": "build/ycloud-vue.js",
  "main": "dist/cjs/ycloud-vue.js",
  "module": "dist/esm/ycloud-vue.mjs",
  "typings": "dist/ycloud-vue.d.ts",
  "sideEffects": false,
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "pnpm clean && pnpm copy:license && pnpm build:icons && pnpm build:bundles",
    "copy:license": "cp ../../LICENSE ./LICENSE",
    "clean": "rm -rf dist && rm -rf ./src/icons/*.ts",
    "build:icons": "build-icons --output=./src --templateSrc=./scripts/exportTemplate.mts --renderUniqueKey --withAliases --aliasesFileExtension=.ts --iconFileExtension=.ts --exportFileName=index.ts",
    "build:bundles": "rollup -c ./rollup.config.mjs",
    "typecheck": "tsc",
    "typecheck:watch": "tsc -w",
    "test": "pnpm build:icons && vitest run",
    "test:watch": "vitest watch"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/vue": "^8.1.0",
    "@vitejs/plugin-vue": "^4.6.2",
    "@vue/test-utils": "2.4.5",
    "@vitejs/plugin-vue2": "2.2.0",
    "rollup-plugin-dts": "^6.1.0",
    "rollup": "^4.59.0",
    "typescript": "^5.8.3",
    "vite": "^7.2.4",
    "vue": "^3.4.21",
    "@ycloud-web/build-icons": "workspace:*",
    "@ycloud-web/rollup-plugins": "workspace:*",
    "@ycloud-web/shared": "workspace:*"
  },
  "peerDependencies": {
    "vue": ">=3.0.1"
  }
}
